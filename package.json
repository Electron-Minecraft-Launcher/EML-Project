		"canvas-confetti": "^1.9.4",
		"fast-xml-parser": "^5.9.3",
		"globals": "^17.7.0",
		"highlight.js": "^11.11.1",
		"mdsvex": "^0.12.7",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^3.5.2",
		"rehype-autolink-headings": "^7.1.0",
		"rehype-slug": "^6.0.0",
		"remark-github-blockquote-alert": "^2.1.0",
		"sass": "^1.101.0",
		"svelte": "^5.56.4",
