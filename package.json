{
	"name": "eml-project",
	"private": true,
	"version": "1.5.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev --host",
		"build": "npm i && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
